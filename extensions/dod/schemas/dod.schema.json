{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/danieldekay/spec-kit-extensions/raw/main/extensions/dod/schemas/dod.schema.json",
  "title": "Spec-Kit Definition of Done",
  "description": "Machine-readable, testable Definition of Done for a feature's Functional Requirements (FR) and Non-Functional Requirements (NFR). Generated by dk.dod.generate after speckit.specify.",
  "type": "object",
  "required": ["meta", "functional_requirements", "non_functional_requirements", "gates"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["extension", "dod_version", "feature_id", "spec_file", "generated_at"],
      "additionalProperties": false,
      "properties": {
        "extension": { "type": "string", "const": "dod" },
        "dod_version": { "type": "string", "pattern": "^\\d+\\.\\d+$" },
        "feature_id": { "type": "string" },
        "spec_file": { "type": "string" },
        "generated_at": { "type": "string", "format": "date-time" },
        "last_validated_at": { "type": ["string", "null"], "format": "date-time" },
        "specfact_compatible": { "type": "boolean" }
      }
    },

    "functional_requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "status", "criteria"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^FR\\d+$",
            "description": "Requirement ID matching the ID in spec.md, e.g. FR1"
          },
          "title": { "type": "string" },
          "priority": {
            "type": "string",
            "enum": ["P1", "P2", "P3", "P4"],
            "description": "Priority inherited from spec.md (P1 = highest)"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "passed", "failed", "skipped"],
            "description": "Aggregate status: passed only when all criteria are passed"
          },
          "criteria": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "description", "type", "test_strategy"],
              "additionalProperties": false,
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^FR\\d+-C\\d+$",
                  "description": "Criterion ID, e.g. FR1-C1"
                },
                "description": { "type": "string" },
                "type": {
                  "type": "string",
                  "enum": ["behavioral", "negative", "boundary", "idempotent", "concurrency"],
                  "description": "Criterion type to guide test design"
                },
                "given": {
                  "type": "string",
                  "description": "Given clause of the Gherkin-style scenario"
                },
                "when": {
                  "type": "string",
                  "description": "When clause of the Gherkin-style scenario"
                },
                "then": {
                  "type": "string",
                  "description": "Then clause — the observable, verifiable outcome"
                },
                "test_strategy": {
                  "type": "string",
                  "enum": ["unit", "integration", "e2e", "contract", "manual"],
                  "description": "Recommended test strategy that exercises this criterion"
                },
                "status": {
                  "type": "string",
                  "enum": ["pending", "passed", "failed", "skipped"],
                  "description": "Criterion-level status updated by dk.dod.validate"
                },
                "evidence": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "test_files": {
                      "type": "array",
                      "items": { "type": "string" },
                      "description": "Relative paths to test files that cover this criterion"
                    },
                    "test_ids": {
                      "type": "array",
                      "items": { "type": "string" },
                      "description": "Test function/case names or IDs that verify this criterion"
                    },
                    "notes": { "type": "string" }
                  }
                }
              }
            }
          },
          "implementation": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "files": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Source files implementing this requirement (populated by dk.dod.validate)"
              },
              "status_note": { "type": "string" }
            }
          }
        }
      }
    },

    "non_functional_requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "category", "status", "criteria"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^NFR\\d+$",
            "description": "Requirement ID matching the ID in spec.md, e.g. NFR1"
          },
          "title": { "type": "string" },
          "category": {
            "type": "string",
            "enum": ["performance", "security", "accessibility", "availability", "scalability", "compatibility", "maintainability"],
            "description": "NFR category — drives default measurement strategy"
          },
          "priority": {
            "type": "string",
            "enum": ["P1", "P2", "P3", "P4"]
          },
          "status": {
            "type": "string",
            "enum": ["pending", "passed", "failed", "skipped"]
          },
          "criteria": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "description", "type", "measurement"],
              "additionalProperties": false,
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^NFR\\d+-C\\d+$"
                },
                "description": { "type": "string" },
                "type": {
                  "type": "string",
                  "enum": ["threshold", "audit", "compliance", "coverage"],
                  "description": "threshold: numeric pass/fail; audit: expert/tooling review; compliance: standard adherence; coverage: percentage target"
                },
                "metric": {
                  "type": "string",
                  "description": "Name of the metric being measured, e.g. response_time_p95"
                },
                "operator": {
                  "type": "string",
                  "enum": ["lt", "lte", "gt", "gte", "eq"],
                  "description": "Comparison operator: lt = less than, lte = less than or equal, etc."
                },
                "value": {
                  "type": ["number", "string", "null"],
                  "description": "Threshold value (null for audit/compliance types)"
                },
                "unit": {
                  "type": "string",
                  "description": "Unit of measurement, e.g. ms, %, requests/s, score"
                },
                "load_profile": {
                  "type": "string",
                  "description": "For performance criteria: the load conditions during measurement"
                },
                "status": {
                  "type": "string",
                  "enum": ["pending", "passed", "failed", "skipped"]
                },
                "measurement": {
                  "type": "object",
                  "required": ["method"],
                  "additionalProperties": false,
                  "properties": {
                    "method": {
                      "type": "string",
                      "enum": ["benchmark", "monitoring", "automated", "audit", "manual"],
                      "description": "How this criterion is measured"
                    },
                    "tool": {
                      "type": "string",
                      "description": "Tool used for measurement, e.g. k6, axe-core, Semgrep"
                    },
                    "command": {
                      "type": "string",
                      "description": "Shell command to run the measurement, used in CI"
                    },
                    "ci_step": {
                      "type": "string",
                      "description": "Name of the CI job step that runs this measurement"
                    }
                  }
                },
                "evidence": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "result": {
                      "type": ["number", "string", "null"],
                      "description": "Measured result value; null until validated"
                    },
                    "measured_at": {
                      "type": ["string", "null"],
                      "format": "date-time"
                    },
                    "report_url": {
                      "type": "string",
                      "description": "URL to the measurement report or CI artifact"
                    },
                    "notes": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },

    "gates": {
      "type": "object",
      "required": ["ready_for_sprint", "definition_of_done"],
      "additionalProperties": false,
      "properties": {
        "ready_for_sprint": {
          "type": "object",
          "required": ["description", "checks", "status"],
          "additionalProperties": false,
          "properties": {
            "description": { "type": "string" },
            "checks": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Plain-language checks that must be true before sprint entry"
            },
            "status": {
              "type": "string",
              "enum": ["pending", "passed", "failed"]
            }
          }
        },
        "definition_of_done": {
          "type": "object",
          "required": ["description", "checks", "status"],
          "additionalProperties": false,
          "properties": {
            "description": { "type": "string" },
            "checks": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Plain-language checks that must be true for the feature to be Done"
            },
            "status": {
              "type": "string",
              "enum": ["pending", "passed", "failed"]
            }
          }
        }
      }
    },

    "specfact": {
      "type": "object",
      "description": "specfact.com integration metadata",
      "additionalProperties": false,
      "properties": {
        "project_id": { "type": ["string", "null"] },
        "feature_tag": { "type": ["string", "null"] },
        "bundle": { "type": ["string", "null"] },
        "enforcement_level": {
          "type": "string",
          "enum": ["observe", "warn", "enforce"]
        },
        "last_exported_at": {
          "type": ["string", "null"],
          "format": "date-time"
        }
      }
    }
  }
}
